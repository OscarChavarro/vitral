#  this is for the bump mapped egg in the back left
newmtl white
Ka 0.1 0.1 0.1
Kd 0.4 0.4 .4
Ks 0.7 .7 .7
Ns 50
illum 2


# this is for the transparent egg in the front left
newmtl clear
Ka .01 .01 .04
Kd .01 .01 .04
Ks .98 .98 .92
illum 2
Ns 50
d .5


# this is for the egg that has the palm texture map in the front right
newmtl neutral
Ka spectral ident .25
Kd spectral ident .75
Ks spectral ident .90
Ns 50
illum 2


# this is for the reflection mapped egg useing a striped map
newmtl gold
Ka spectral gold.pl .01
Kd spectral gold.pl .3
Ks spectral gold.pl 1
Ns 75
illum 3

