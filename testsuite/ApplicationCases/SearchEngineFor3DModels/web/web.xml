<?xml version="1.0" encoding="ISO-8859-1"?>

<!DOCTYPE web-app
    PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
    "http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>

    <display-name>VITRAL-based search engine for 3d models</display-name>

    <description>
    Tested under Linux Fedora Core 4 (kernel 2.6.16), with Java JDK 1.6.0
    (x86_64 version running on an AMD64) amd Tomcat (catalina) version
    6.0.13, june 2007.
    </description>

    <servlet>
        <servlet-name>ServletConsole</servlet-name>
        <servlet-class>ServletConsole</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ServletConsole</servlet-name>
        <url-pattern>/ServletConsole</url-pattern>
    </servlet-mapping>

</web-app>
