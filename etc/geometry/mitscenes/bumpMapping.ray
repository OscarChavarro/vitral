#
# Sphere with texture + bump map, modeled after ShadersExample first frame.
#

viewport 1280 720

eye 0 -4 0
up 0 0 1
lookat 0 0 0
fov 50
background 0 0 0

surface 1 1 1 0.1 1.0 1.0 40 0.0 0.0 1.0
texture "../../../etc/textures/miniearth.png"
bumpmap "../../../etc/bumpmaps/earth.bw" 1 1 0.2
rotation 1.2 0 0
sphere 0 0 0 1
rotation 0 0 0

light 0.12 0.12 0.12 ambient
light 1 1 1 point 1 -3 1
